rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isEmployee() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != "anonymous"
        && request.auth.token.email == "ethagemployee@gmail.com";
    }

    function isAnonymousClient() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == "anonymous";
    }

    match /uploads/{userId}/{customerId}/{fileName} {
      allow read: if isEmployee();
      allow write: if isAnonymousClient() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
